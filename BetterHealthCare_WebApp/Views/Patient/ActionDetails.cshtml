@using BetterHealthCare_WebApp.Models.Patients
@model PatientActionDetailViewModel

@functions {
    bool IsImage(string? fileName)
    {
        if (string.IsNullOrWhiteSpace(fileName)) return false; // <- handle null

        var extensions = new[] { ".jpg", ".jpeg", ".png", ".gif", ".bmp", ".webp" };
        var ext = System.IO.Path.GetExtension(fileName)?.ToLowerInvariant();
        return ext != null && extensions.Contains(ext);
    }
}

<h2>Patient Action Details</h2>

<div class="mb-3">
    <strong>Procedure:</strong> @Model.Action.Procedure.Name (@Model.Action.Procedure.Type) <br />
    <strong>Date:</strong> @Model.Action.DateOfProcedure.ToShortDateString()
</div>

<h4>Files</h4>
@if (Model.Files.Any())
{
    <div class="row">
        @foreach (var file in Model.Files)
        {
            <div class="col-md-2 mb-3 text-center">
                <p class="small mb-1">@file.FileName</p>

                @if (IsImage(file.FileName) && file.Base64 != null)
                {
                    <!-- Actual images shown naturally, max width responsive -->
                    <img src="data:image;base64,@file.Base64"
                         class="img-fluid img-thumbnail mb-1"
                         alt="@file.FileName" />
                }
                else
                {
                    <!-- Non-images use small placeholder -->
                    <img src="~/images/pdf-placeholder.png"
                         class="img-thumbnail mb-1"
                         style="max-width: 100px; max-height: 100px; height: auto;"
                         alt="PDF placeholder" />
                }

                <br />
                <a class="btn btn-sm btn-outline-primary"
                   href="@Url.Action("Download", "MedicalFile", new { id = file.Id, fileName = file.FileName })">
                    Download
                </a>
            </div>
        }
    </div>
}
else
{
    <p>No files uploaded for this action.</p>
}

<div class="mt-3">
    <a class="btn btn-secondary"
       href="@Url.Action("Details", "Patient", new { id = Model.PatientId })">
        Back to Patient
    </a>
</div>