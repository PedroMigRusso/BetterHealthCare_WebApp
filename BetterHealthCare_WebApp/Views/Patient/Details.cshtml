@using BetterHealthCare_WebApp.Models.Patients
@model PatientDto

@{
    ViewData["Title"] = "Patient Details";
}

<h2>Patient Details</h2>

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">@Model.Name</h5>
        <p class="card-text"><strong>Health Number:</strong> @Model.HealthNumber</p>
        <p class="card-text"><strong>Date of Birth:</strong> @Model.DateOfBirth.ToShortDateString()</p>
        <p class="card-text"><strong>Date of Creation:</strong> @Model.DateOfCreation.ToShortDateString()</p>
    </div>
</div>

<div class="mt-3">
    <a class="btn btn-warning" href="@Url.Action("Edit", new { id = Model.Id })">Edit</a>
    <a class="btn btn-danger" href="@Url.Action("Delete", new { id = Model.Id })">Delete</a>
    <a class="btn btn-secondary" href="@Url.Action("Index")">Back to List</a>
</div>
