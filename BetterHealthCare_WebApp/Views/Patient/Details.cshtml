@using BetterHealthCare_WebApp.Models.Patients
@model PatientDto

<a class="btn btn-secondary mb-3" href="@Url.Action("Index", "Patient")">← Back to Patients</a>


<h2>Detalhes do Paciente</h2>
<p><strong>Nome:</strong> @Model.Name</p>
<p><strong>Número de Saúde:</strong> @Model.HealthNumber</p>
<p><strong>Data de Nascimento:</strong> @Model.DateOfBirth.ToShortDateString()</p>

<h3>Procedimentos Associados</h3>
@if (Model.Actions.Any())
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>Procedure</th>
                <th>Date</th>
                <th>Files</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var action in Model.Actions)
            {
                <tr>
                    <td>@action.Procedure.Name (@action.Procedure.Type)</td>
                    <td>@action.DateOfProcedure.ToShortDateString()</td>
                    <td>
                        @if (action.FilesId != null && action.FilesId.Any())
                        {
                            <span>@string.Join(", ", action.FilesId)</span>
                        }
                    </td>
                    <td>
                        <form asp-action="DeleteAction" method="post" class="d-inline">
                            <input type="hidden" name="patientId" value="@Model.Id" />
                            <input type="hidden" name="actionId" value="@action.Id" />
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('Are you sure you want to delete this action?');">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Este paciente não tem procedimentos associados.</p>
}
<a class="btn btn-success"
   href="@Url.Action("AddAction", "Patient", new { patientId = Model.Id })">
    + Add Procedure
</a>

