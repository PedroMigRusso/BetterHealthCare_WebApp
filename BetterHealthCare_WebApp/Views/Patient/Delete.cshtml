@using BetterHealthCare_WebApp.Models.Patients
@model PatientDto

@{
    ViewData["Title"] = "Delete Patient";
}

<h2>Delete Patient</h2>

<h3>Are you sure you want to delete this patient?</h3>

<div>
    <h4>Patient</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Birth Date</dt>
        <dd class="col-sm-10">@Model.DateOfBirth.ToShortDateString()</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.HealthNumber</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
